# CIO Prototype - Environment Variables Template
# Copy this file to .env and fill in your actual keys.

# =============================================================================
# AI API Keys
# =============================================================================

# Gemini API Key (Required)
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API Key (Optional, for Claude - recommended for LLM strategy optimization)
# Best model per paper findings (+14.1% avg P&L improvement vs Gemini +7.3%)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq API Key (Optional fallback)
# Get from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# Data Source API Keys
# =============================================================================

# EDINET API Key (Optional, for Japanese stock reports)
# Get from: https://disclosure2dl.edinet-fsa.go.jp/
EDINET_API_KEY=your_edinet_subscription_key_here

# EDINET DB API Key (Optional, for Japanese stock financials + AI analysis)
# Get from: https://edinetdb.jp/
EDINETDB_API_KEY=your_edinetdb_api_key_here

# J-Quants API Key (Optional, for TSE official OHLC stock prices)
# Get from: https://jpx-jquants.com/
JQUANTS_API_KEY=your_jquants_api_key_here

# Finnhub API Key (Optional, for US stock news — TSE/Japanese stocks are NOT supported)
# For Japanese stocks, Google News RSS (free, no key required) is used instead.
# Get from: https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here

# Exa API Key (Optional, for web search news — Japanese stocks)
# Get from: https://exa.ai/
EXA_API_KEY=your_exa_api_key_here

# Perplexity API Key (Optional, web search news fallback)
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Tavily API Key (Optional, web search news fallback)
# Get from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# SEC EDGAR User-Agent (Required for US stocks)
# Format: YourName (your-email@example.com)
SEC_USER_AGENT=YourName (your-email@example.com)

# =============================================================================
# Google Sheets (Optional)
# =============================================================================
# Choose ONE of the following authentication methods:
#
# Method 1: JSON String (Recommended for cloud deployment)
# - Copy the entire service account JSON content here
# - Get from: Google Cloud Console > IAM & Admin > Service Accounts
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# Method 2: File Path (Recommended for local development)
# - Place your service account JSON file in the secret/ directory
# - Reference the relative or absolute path
GOOGLE_SHEETS_KEY_PATH=secret/your-key-file.json

# Google Sheets Spreadsheet ID (Required if using Google Sheets output)
# - The ID is the long string in the URL: docs.google.com/spreadsheets/d/[THIS_ID]/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# =============================================================================
# LINE Messaging API (Optional)
# =============================================================================
# Get from: LINE Developers Console > Your Channel > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_USER_ID=your_line_user_id_here

# =============================================================================
# LINE Notify (Optional - アラート通知)
# =============================================================================
# LINE Notify は LINE Messaging API より簡単です（トークン1つで送信可能）。
# 取得方法: https://notify-bot.line.me/my/ でトークンを発行
# ※ LINE Messaging API (LINE_CHANNEL_ACCESS_TOKEN/LINE_USER_ID) とは別物です
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# =============================================================================
# Notion (Optional)
# =============================================================================
# Get API key from: https://www.notion.so/my-integrations
# Database ID: The long ID in your Notion database URL
# (e.g. notion.so/username/[THIS_IS_THE_DATABASE_ID]?v=...)
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here
